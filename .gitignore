# --- Python / tooling ---
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
*.egg-info/
.venv/

# --- Data: raw & split data files are not committed; only small metadata/logs are ---
data/*
!data/kaggle/
!data/crisislex/
